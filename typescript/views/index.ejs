<!DOCTYPE html>
<html>
<head>
    <title>Vulnerable TypeScript App</title>
</head>
<body>
    <!-- VULNERABILITY: Reflected XSS via EJS unescaped output -->
    <h1>Welcome <%- name %></h1>
    <div><%- message %></div>

    <!-- VULNERABILITY: DOM XSS -->
    <script>
        document.write("Hello " + location.hash.slice(1));
    </script>

    <!-- VULNERABILITY: Eval with user-controlled data -->
    <script>
        var data = <%- userData %>;
        eval(data);
    </script>
</body>
</html>
